{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "static/js/**/*.js",
    "static/js/**/*.d.ts"
  ],
  "exclude": [
    "static/sw.js"
  ]
}
