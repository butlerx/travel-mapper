  "query": "SELECT\n                   h.travel_type,\n                   h.origin_name,\n                   h.origin_lat,\n                   h.origin_lng,\n                   h.origin_country,\n                   h.dest_name,\n                   h.dest_lat,\n                   h.dest_lng,\n                   h.dest_country,\n                   h.start_date,\n                   h.end_date,\n                   fd.airline,\n                   fd.aircraft_type,\n                   fd.cabin_class,\n                   fd.seat_type,\n                   fd.flight_reason\n               FROM hops h\n               LEFT JOIN flight_details fd ON fd.hop_id = h.id\n               WHERE h.user_id = ?\n               ORDER BY h.start_date ASC",
